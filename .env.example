# Database Configuration
# PostgreSQL credentials for Dagster metadata storage and pipeline data
POSTGRES_USER=dagster
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=mama_health
POSTGRES_PORT=5432
POSTGRES_HOST=postgres

# Dagster Configuration
DAGSTER_WEBSERVER_PORT=3000
DAGSTER_DAEMON_LOG_LEVEL=INFO

# Reddit API Credentials
# Register your app at: https://www.reddit.com/prefs/apps
# Create a "script" app type to get credentials
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=mama-health-ai-challenge/0.1.0 (contact: your_email@example.com)
REDDIT_USERNAME=your_reddit_username_here
REDDIT_PASSWORD=your_reddit_password_here

# Google Gemini API
# Get a free API key from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# Pipeline Configuration
# Subreddit to analyze (examples: Crohns, MultipleSclerosis, rheumatoidarthritis, diabetes, endometriosis)
TARGET_SUBREDDIT=Crohns
POSTS_LIMIT=100
COMMENTS_LIMIT=50
REDDIT_SEARCH_LIMIT_DAYS=30

# LLM Configuration
# litellm model specification
LLM_MODEL=gemini/gemini-pro
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1000

# Optional: Rate limiting and timeouts
REDDIT_REQUEST_TIMEOUT=30
LLM_REQUEST_TIMEOUT=60
REDDIT_RATE_LIMIT_PER_MINUTE=60

# Logging
LOG_LEVEL=INFO
